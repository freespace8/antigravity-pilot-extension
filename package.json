{
  "name": "antigravity-extention",
  "displayName": "Antigravity Extension",
  "description": "Status bar entry and CDP controller scaffold for Antigravity windows.",
  "version": "0.0.1",
  "publisher": "freespace8",
  "private": true,
  "engines": {
    "vscode": "^1.85.0"
  },
  "categories": [
    "Other"
  ],
  "activationEvents": [
    "onCommand:agPerf.openMenu",
    "onCommand:agPerf.recoverOff"
  ],
  "main": "./dist/extension.js",
  "contributes": {
    "commands": [
      {
        "command": "agPerf.openMenu",
        "title": "AG Perf: Open Menu",
        "category": "AG Perf"
      },
      {
        "command": "agPerf.recoverOff",
        "title": "AG Perf: Recover Off",
        "category": "AG Perf"
      }
    ]
  },
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "compile": "npm run build",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "test": "npm run test:unit && npm run test:integration",
    "test:unit": "jest --config jest.unit.config.cjs",
    "test:integration": "jest --config jest.integration.config.cjs --passWithNoTests"
  },
  "dependencies": {
    "ws": "^8.18.3"
  },
  "devDependencies": {
    "@types/jest": "^30.0.0",
    "@types/node": "^24.3.0",
    "@types/vscode": "^1.105.0",
    "@types/ws": "^8.18.1",
    "jest": "^30.1.3",
    "ts-jest": "^29.4.1",
    "typescript": "^5.9.2"
  }
}
